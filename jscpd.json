{
    "threshold": 3,
    "minLines": 8,
    "minTokens": 80,
    "reporters": [
        "console"
    ],
    "pattern": "**/*.{ts,tsx}",
    "ignore": [
        "**/node_modules/**",
        "**/dist/**",
        "**/coverage/**",
        "**/.codex-research/**",
        "packages/*/renderer/src/index.js"
    ]
}
