{
    "name": "melos-monorepo",
    "version": "0.0.1",
    "packageManager": "bun@1.3.3",
    "workspaces": [
        "packages/*"
    ],
    "devDependencies": {
        "@biomejs/biome": "^2.5.0",
        "@eslint/js": "^9.39.4",
        "@typescript-eslint/eslint-plugin": "^8.61.0",
        "@typescript-eslint/parser": "^8.61.0",
        "@typescript/native-preview": "^7.0.0-dev.20260614.1",
        "bun-types": "^1.3.14",
        "dependency-cruiser": "^17.4.3",
        "eslint": "^9.39.4",
        "globals": "^17.6.0",
        "jscpd": "^5.0.9",
        "knip": "^6.16.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.61.0"
    },
    "scripts": {
        "build": "bun run --filter '*' build",
        "test": "bun test",
        "typecheck": "tsgo --noEmit -p tsconfig.json",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "quality:audit": "bun scripts/quality-audit.ts",
        "quality:biome": "biome lint .",
        "quality:knip": "knip --no-config-hints",
        "quality:dup": "jscpd --config jscpd.json packages",
        "quality:arch": "depcruise packages --validate .dependency-cruiser.cjs",
        "quality": "bun typecheck && bun run format:check && bun run lint && bun run quality:biome && bun run quality:audit && bun run quality:knip && bun run quality:arch && bun run quality:dup && bun test"
    }
}
